    {# ── RESEARCH EXCELLENCE ── #}
    <section class="cs-pg-excellence">
      <div class="cs-pg-excellence__inner">
        <div class="cs-pg-excellence__text">
          <h2>Research Excellence</h2>
          <p>
            Our PhD programme emphasises rigorous, publishable research. You'll be expected to contribute
            meaningfully to the international body of knowledge in computer science through original work
            that meets the highest academic standards.
          </p>
          <ul class="cs-pg-excellence__points">
            <li>Original, publishable research contributions</li>
            <li>Publication in top-tier conferences and journals</li>
            <li>Collaboration with international research partners</li>
            <li>Presentation at major conferences worldwide</li>
            <li>Development of independent research leadership</li>
          </ul>
        </div>
        <div class="cs-pg-excellence__highlights">
          <div class="cs-pg-highlight">
            <span class="cs-pg-highlight__number">50+</span>
            <span class="cs-pg-highlight__label">Annual Publications</span>
          </div>
          <div class="cs-pg-highlight">
            <span class="cs-pg-highlight__number">11</span>
            <span class="cs-pg-highlight__label">Faculty Supervisors</span>
          </div>
        </div>
      </div>
    </section>

