    <section class="cs-pg-intro">
      <div class="cs-pg-intro__text">
        <h2 class="cs-section-label">Doctor of Philosophy in Computer Science</h2>
        <p>
          The PhD is the highest research degree, designed for exceptional scholars committed to making
          original contributions to computer science knowledge through independently conducted research.
          You'll work at the frontier of the field, pushing the boundaries of what's known and possible.
        </p>
      </div>
      <div class="cs-pg-intro__highlights">
        <div class="cs-pg-highlight">
          <span class="cs-pg-highlight__number">3–4</span>
          <span class="cs-pg-highlight__label">Years Full-Time</span>
        </div>
        <div class="cs-pg-highlight">
          <span class="cs-pg-highlight__number">200+</span>
          <span class="cs-pg-highlight__label">Page Dissertation</span>
        </div>
        <div class="cs-pg-highlight">
          <span class="cs-pg-highlight__number">9+</span>
          <span class="cs-pg-highlight__label">Research Areas</span>
        </div>
      </div>
    </section>

