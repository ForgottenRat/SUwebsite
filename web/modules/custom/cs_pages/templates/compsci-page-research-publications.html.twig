      entries.forEach(function(e){
        if (e.isIntersecting && !observed) {
          observed = true;
          nums.forEach(function(el){
            var target = parseInt(el.getAttribute('data-pub-count'), 10);
            var suffix = el.getAttribute('data-pub-suffix') || '';
            var dur = 1400, start = null;
            function step(ts){
              if (!start) start = ts;
              var p = Math.min((ts - start) / dur, 1);
              var ease = 1 - Math.pow(1 - p, 3);
              el.textContent = Math.floor(target * ease) + suffix;
              if (p < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
          });
        }
      });
    }, { threshold: 0.3 });
    obs.observe(document.querySelector('.cs-pub-numbers'));
  }

  /* ── Filter tabs ── */
  var tabs = document.querySelectorAll('[data-pub-filter]');
  var entries = document.querySelectorAll('[data-pub-area]');
  tabs.forEach(function(tab){
    tab.addEventListener('click', function(){
      tabs.forEach(function(t){ t.classList.remove('cs-pub-tab--active'); });
      tab.classList.add('cs-pub-tab--active');
      var f = tab.getAttribute('data-pub-filter');
      entries.forEach(function(entry){
        if (f === 'all' || entry.getAttribute('data-pub-area') === f) {
          entry.style.display = '';
          entry.style.animation = 'pubFadeIn 0.35s ease forwards';
        } else {
          entry.style.display = 'none';
        }
      });
    });
  });

  /* ── Bar chart animation ── */
  var barsObs = false;
  var barsSection = document.querySelector('.cs-pub-bars');
  if (barsSection) {
    var bObs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting && !barsObs) {
          barsObs = true;
          barsSection.classList.add('cs-pub-bars--visible');
        }
      });
    }, { threshold: 0.2 });
    bObs.observe(barsSection);
  }

  /* ── Area bars animation ── */
  var areasObs = false;
  var areasSection = document.querySelector('.cs-pub-area-grid');
  if (areasSection) {
    var aObs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting && !areasObs) {
          areasObs = true;
          areasSection.classList.add('cs-pub-area-grid--visible');
        }
      });
    }, { threshold: 0.2 });
    aObs.observe(areasSection);
  }
})();
</script>
