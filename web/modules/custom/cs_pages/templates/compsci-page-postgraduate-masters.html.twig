<div class="cs-content">
  <div class="cs-content__inner">
    <h1>Master's Programme</h1>
  </div>
  <div class="cs-content__inner">

    {# ── INTRO ── #}
    <section class="cs-pg-intro">
      <div class="cs-pg-intro__text">
        <h2 class="cs-section-label">MSc in Computer Science</h2>
        <p>
          The Master's degree is a research-intensive postgraduate qualification offering students the
          opportunity to conduct original research in computer science under expert faculty supervision.
          You'll develop deep expertise in your chosen area while contributing new knowledge to the field.
        </p>
      </div>
      <div class="cs-pg-intro__highlights">
        <div class="cs-pg-highlight">
          <span class="cs-pg-highlight__number">2–3</span>
          <span class="cs-pg-highlight__label">Years Full-Time</span>
        </div>
        <div class="cs-pg-highlight">
          <span class="cs-pg-highlight__number">100+</span>
          <span class="cs-pg-highlight__label">Page Thesis</span>
        </div>
        <div class="cs-pg-highlight">
          <span class="cs-pg-highlight__number">8+</span>
          <span class="cs-pg-highlight__label">Research Areas</span>
        </div>
      </div>
    </section>

    {# ── PROGRAMME STRUCTURE ── #}
    <section class="cs-pg-structure">
      <h2 class="cs-section-label cs-section-label--center">Programme Structure</h2>
      <div class="cs-pg-structure__grid">
        <div class="cs-pg-structure-card">
          <div class="cs-pg-structure-card__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="cs-pg-structure-card__title">Coursework Component</h3>
          <span class="cs-pg-structure-card__credits">Varies by track</span>
          <p>Select specialisation modules that complement your research direction and deepen your theoretical foundation.</p>
        </div>
        <div class="cs-pg-structure-card">
          <div class="cs-pg-structure-card__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3 class="cs-pg-structure-card__title">Research Thesis</h3>
          <span class="cs-pg-structure-card__credits">Original contribution (100+ pages)</span>
          <p>Conduct original research under expert supervision, resulting in a thesis that advances the field.</p>
        </div>
        <div class="cs-pg-structure-card">
          <div class="cs-pg-structure-card__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="cs-pg-structure-card__title">Duration</h3>
          <span class="cs-pg-structure-card__credits">Flexible options</span>
          <p>2 years full-time (standard) or up to 5 years part-time for working professionals.</p>
        </div>
      </div>
    </section>

    {# ── RESEARCH AREAS ── #}
    <section class="cs-pg-research">
      <h2 class="cs-section-label cs-section-label--center">Research Areas</h2>
      <p class="cs-pg-research__lead">Master's students can pursue research across a wide range of topics.</p>
      <div class="cs-pg-research__tags">
        <span class="cs-pg-research-tag">Machine Learning &amp; AI</span>
        <span class="cs-pg-research-tag">Data Science &amp; Big Data</span>
        <span class="cs-pg-research-tag">Cybersecurity &amp; Privacy</span>
        <span class="cs-pg-research-tag">Software Engineering</span>
        <span class="cs-pg-research-tag">Computer Networks</span>
        <span class="cs-pg-research-tag">Bioinformatics</span>
        <span class="cs-pg-research-tag">Formal Methods</span>
        <span class="cs-pg-research-tag">Human-Computer Interaction</span>
      </div>
    </section>

    {# ── SUPERVISION ── #}
    <section class="cs-pg-supervision">
      <div class="cs-pg-supervision__inner">
        <div class="cs-pg-supervision__text">
          <h2>Faculty Supervision</h2>
          <p>
            Each Master's student is assigned a faculty supervisor with deep expertise in their research area.
            Our faculty members are active researchers who publish in top-tier international venues and provide
            dedicated mentorship throughout your programme.
          </p>
          <ul class="cs-pg-supervision__points">
            <li>One-on-one research guidance</li>
            <li>Regular progress meetings</li>
            <li>Publication support and co-authorship</li>
            <li>Conference presentation opportunities</li>
          </ul>
        </div>
        <div class="cs-pg-supervision__highlights">
          <div class="cs-pg-highlight">
            <span class="cs-pg-highlight__number">11</span>
            <span class="cs-pg-highlight__label">Faculty Supervisors</span>
          </div>
          <div class="cs-pg-highlight">
            <span class="cs-pg-highlight__number">6+</span>
            <span class="cs-pg-highlight__label">Research Groups</span>
          </div>
        </div>
      </div>
    </section>

    {# ── ADMISSION REQUIREMENTS ── #}
    <section class="cs-pg-admission">
      <h2 class="cs-section-label cs-section-label--center">Admission Requirements</h2>
      <div class="cs-pg-req-grid">
        <div class="cs-pg-req-card">
          <div class="cs-pg-req-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <h3 class="cs-pg-req-card__title">Honours or Equivalent</h3>
          <p>An Honours degree or equivalent postgraduate qualification in Computer Science or related field.</p>
        </div>
        <div class="cs-pg-req-card">
          <div class="cs-pg-req-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="cs-pg-req-card__title">Minimum 65% GPA</h3>
          <p>A strong academic record with a minimum undergraduate GPA typically of 65% or higher.</p>
        </div>
        <div class="cs-pg-req-card">
          <div class="cs-pg-req-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3 class="cs-pg-req-card__title">Research Motivation</h3>
          <p>Strong research interest and motivation, with a clear statement of research interests.</p>
        </div>
        <div class="cs-pg-req-card">
          <div class="cs-pg-req-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
          </div>
          <h3 class="cs-pg-req-card__title">Supervisor Available</h3>
          <p>Faculty approval and an available supervisor for your proposed research topic.</p>
        </div>
      </div>
    </section>

    {# ── CAREER OUTCOMES ── #}
