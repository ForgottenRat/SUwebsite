    {# ===== TOOLS & SOFTWARE ===== #}
    <section class="cs-res-tools">
      <div class="cs-res-tools__inner">
        <div class="cs-res-tools__text">
          <h2>Tools &amp; Software</h2>
          <p>As a CS student at Stellenbosch, you have access to industry-standard tools and platforms free of charge.</p>
          <ul class="cs-res-tools__list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--cs-gold)" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>GitHub Student Developer Pack</strong> &mdash; Free Pro account, Copilot, and 80+ tools
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--cs-gold)" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>JetBrains Education</strong> &mdash; Free IntelliJ, PyCharm, CLion, and all JetBrains IDEs
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--cs-gold)" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>Microsoft Azure</strong> &mdash; Free credits and developer tools via Azure for Students
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--cs-gold)" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>AWS Educate</strong> &mdash; Cloud computing credits and training resources
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--cs-gold)" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>Overleaf Premium</strong> &mdash; LaTeX editor for reports and theses (through SU licence)
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--cs-gold)" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
              <strong>MATLAB &amp; Mathematica</strong> &mdash; Campus-wide licences for scientific computing
            </li>
