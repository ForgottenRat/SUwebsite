          <h3>Graduate Coordinator</h3>
          <p><a href="mailto:graduate-coordinator@sun.ac.za">graduate-coordinator@sun.ac.za</a></p>
        </div>
        <div class="cs-pg-contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <h3>Department Website</h3>
          <p><a href="https://cs.sun.ac.za" target="_blank">cs.sun.ac.za</a></p>
        </div>
        <div class="cs-pg-contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <h3>Visit Campus</h3>
          <p>Contact the graduate office to arrange a campus visit and meet faculty.</p>
        </div>
      </div>
    </section>

    {# ── CTA ── #}
    <section class="cs-about-cta">
      <h2 class="cs-about-cta__heading">Ready to Begin Your Postgraduate Journey?</h2>
      <p class="cs-about-cta__text">Visit the university's admissions portal or contact us directly to get started.</p>
      <div class="cs-about-cta__buttons">
        <a href="/contact" class="cs-about-cta__btn cs-about-cta__btn--primary">Contact Us</a>
        <a href="/postgraduate" class="cs-about-cta__btn cs-about-cta__btn--secondary">Postgraduate Overview →</a>
      </div>
    </section>

  </div>
</div>
